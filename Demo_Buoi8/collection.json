                {
                  "name": "{book_id}",
                  "item": [
                    {
                      "name": "Get book by ID",
                      "event": [
                        {
                          "listen": "test",
                          "script": {
                            "exec": [
                              "// 1. Status code\r",
                              "pm.test(\"Status 200\", () => {\r",
                              "    pm.response.to.have.status(200);\r",
                              "});\r",
                              "\r",
                              "// 2. Response time\r",
                              "pm.test(\"Response time < 500ms\", () => {\r",
                              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
                              "});\r",
                              "\r",
                              "// 3. Content-Type\r",
                              "pm.test(\"Content-Type là JSON\", () => {\r",
                              "    pm.expect(pm.response.headers.get(\"Content-Type\"))\r",
                              "        .to.include(\"application/json\");\r",
                              "});\r",
                              "\r",
                              "// 4. Parse JSON\r",
                              "const json = pm.response.json();\r",
                              "\r",
                              "// 5. Check structure\r",
                              "pm.test(\"Có data và meta\", () => {\r",
                              "    pm.expect(json).to.have.property(\"data\");\r",
                              "    pm.expect(json).to.have.property(\"meta\");\r",
                              "});\r",
                              "\r",
                              "// 6. Check đúng ID\r",
                              "pm.test(\"Đúng book_id\", () => {\r",
                              "    pm.expect(json.data.id).to.eql(pm.environment.get(\"book_id\"));\r",
                              "});\r",
                              "\r",
                              "// 7. Validate field tồn tại\r",
                              "pm.test(\"Có đủ field\", () => {\r",
                              "    pm.expect(json.data).to.have.property(\"title\");\r",
                              "    pm.expect(json.data).to.have.property(\"author\");\r",
                              "});\r",
                              "\r",
                              "// 8. Validate kiểu dữ liệu\r",
                              "pm.test(\"Field đúng kiểu\", () => {\r",
                              "    pm.expect(json.data.id).to.be.a(\"string\");\r",
                              "    pm.expect(json.data.title).to.be.a(\"string\");\r",
                              "    pm.expect(json.data.author).to.be.a(\"string\");\r",
                              "});\r",
                              "\r",
                              "// 9. Validate dữ liệu hợp lệ\r",
                              "pm.test(\"title & author không rỗng\", () => {\r",
                              "    pm.expect(json.data.title.length).to.be.above(0);\r",
                              "    pm.expect(json.data.author.length).to.be.above(0);\r",
                              "});\r",
                              "\r",
                              "// 10. Meta hợp lệ\r",
                              "pm.test(\"meta có timestamp\", () => {\r",
                              "    pm.expect(json.meta).to.have.property(\"timestamp\");\r",
                              "});"
                            ],
                            "type": "text/javascript",
                            "packages": {},
                            "requests": {}
                          }
                        }
